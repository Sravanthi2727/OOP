<canvas id="bg-canvas"></canvas>
<header>
  <nav class="navbar">
    <div class="logo">VISIONVAULT</div>
    <ul class="nav-links">
      <li><a href="#features">Courses</a></li>
      <li><a href="#features">Jobs</a></li>
      <li><a href="#features">Hackathons</a></li>
      <li><a href="#features">Quiz</a></li>
    </ul>

    <!-- right side actions -->
    <div id="navActions">
      <button id="openAuthBtn" class="login-btn" onclick="showView('auth-modal')">Login / Sign Up</button>
    </div>

    <div class="hamburger">
      <i class="fas fa-bars"></i>
    </div>
  </nav>
</header>

<div id="auth-modal" class="view auth-modal">
  <div class="auth-container">
    <div class="auth-tabs">
      <button id="tabLogin" class="tab active" onclick="switchTab('login')">Login</button>
      <button id="tabSignup" class="tab" onclick="switchTab('signup')">Sign up</button>
    </div>

    <div id="login-view" class="auth-view active">
      <h3 class="auth-title">Welcome back</h3>
      <form id="loginForm" class="auth-form">
        <input type="email" id="loginEmail" placeholder="Email" required />
        <input type="password" id="loginPassword" placeholder="Password" required minlength="8" />
        <div style="display:flex;gap:8px;align-items:center;justify-content:space-between;">
          <button type="submit" class="login-btn" style="padding:0.6rem 1.2rem">Login</button>
          <a href="#" onclick="showForgot()" style="color:#00ffff;text-decoration:underline;">Forgot password?</a>
        </div>
        <p id="loginMessage" class="auth-message"></p>
      </form>
    </div>

    <div id="signup-view" class="auth-view">
      <h3 class="auth-title">Create your account</h3>
      <form id="signupForm" class="auth-form">
        <input type="text" id="name" placeholder="Full Name" required />
        <input type="email" id="email" placeholder="Email" required />
        <input type="password" id="password" placeholder="Password (min 8 chars)" required minlength="8" />
        <button type="submit" class="login-btn" style="width:100%;padding:0.6rem 1.2rem">Sign Up</button>
        <p id="formMessage" class="auth-message"></p>
      </form>
    </div>

    <div id="forgot-view" class="auth-view">
      <h3 class="auth-title">Reset password</h3>
      <form id="forgotForm" class="auth-form">
        <input type="email" id="forgotEmail" placeholder="Enter your account email" required />
        <button type="submit" class="login-btn" style="width:100%;padding:0.6rem 1.2rem">Send reset link</button>
        <p id="forgotMessage" class="auth-message"></p>
      </form>
      <p style="text-align:center;margin-top:12px;">
        <a href="#" onclick="switchTab('login')" style="color:#00ffff;text-decoration:underline;">Back to login</a>
      </p>
    </div>

    <div id="thank-you" class="auth-view">
      <div style="text-align:center;padding:1.5rem;">
        <svg xmlns="http://www.w3.org/2000/svg" class="text-green-500 w-20 h-20 mb-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
        </svg>
        <h1 style="color:#00ffcc;margin-bottom:8px;">✅ Email Verified!</h1>
        <p id="verifiedMsg" style="color:#ddd;">Thank you — your account is now active. Redirecting to home...</p>
        <button onclick="backToHome()" class="login-btn" style="margin-top:12px;padding:0.5rem 1rem;">Back to Home</button>
      </div>
    </div>

    <div style="text-align:center;margin-top:0.6rem;">
      <button onclick="closeAuth()" class="mt-2" style="background:none;border:none;color:#aaa;text-decoration:underline;cursor:pointer;">Close</button>
    </div>
  </div>
</div>

<style>
.auth-modal { position: fixed; inset: 0; display: none; align-items: center; justify-content: center; z-index: 2000; }
.auth-modal.active { display: flex; background: rgba(0,0,0,0.6); }
.auth-container { background: rgba(10,15,20,0.9); border-radius: 12px; padding: 1.5rem; width: 420px; max-width: 92%; border: 1px solid rgba(0,255,255,0.08); }
.auth-tabs { display:flex; gap:8px; margin-bottom:12px; }
.auth-tabs .tab { flex:1; padding:8px; border-radius:8px; background:transparent; color:#ddd; border:none; cursor:pointer; }
.auth-tabs .tab.active { background: linear-gradient(45deg,#00ffff,#0077ff); color:#111; font-weight:700; }
.auth-view { display:none; }
.auth-view.active { display:block; }
.auth-title { color:#fff; margin-bottom:12px; text-align:center; font-weight:700; }
.auth-form input { width:100%; padding:10px; margin-bottom:10px; border-radius:8px; border:1px solid rgba(255,255,255,0.06); background:rgba(255,255,255,0.03); color:#fff; }
.auth-message { margin-top:8px; color:#ffb3b3; text-align:center; font-size:0.95rem; }
</style>

<script>
  function openAuth() { document.getElementById('auth-modal').classList.add('active'); }
  function closeAuth() { document.getElementById('auth-modal').classList.remove('active'); }
  function showView(viewId) {
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    const view = document.getElementById(viewId);
    if (view) view.classList.add('active');
  }
  function switchTab(tab) {
    document.querySelectorAll('.auth-tabs .tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.auth-view').forEach(v => v.classList.remove('active'));
    if (tab === 'login') {
      document.getElementById('tabLogin').classList.add('active');
      document.getElementById('login-view').classList.add('active');
    } else {
      document.getElementById('tabSignup').classList.add('active');
      document.getElementById('signup-view').classList.add('active');
    }
    openAuth();
  }
  function showForgot() {
    openAuth();
    document.querySelectorAll('.auth-tabs .tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.auth-view').forEach(v => v.classList.remove('active'));
    document.getElementById('forgot-view').classList.add('active');
  }

  function updateNavbar(name) {
    const navActions = document.getElementById('navActions');
    if (!navActions) return;
    navActions.innerHTML = `
      <span style="color:#fff;font-weight:600;margin-right:12px;">Welcome, ${name} 👋</span>
      <button onclick="logout()" style="background:transparent;border:none;color:#ff6b6b;text-decoration:underline;cursor:pointer;">Logout</button>
    `;
  }
  function logout() { localStorage.removeItem('userName'); location.reload(); }
  function backToHome() {
    const name = localStorage.getItem('userName');
    if (name) updateNavbar(name);
    closeAuth();
    window.location.hash = '';
    showView('landing-page');
  }

  document.addEventListener('DOMContentLoaded', () => {
    const urlHash = window.location.hash || '';
    if (urlHash.startsWith('#verified')) {
      const urlParams = new URLSearchParams(window.location.hash.split('?')[1]);
      const verifiedName = urlParams.get('name');
      if (verifiedName) {
        localStorage.setItem('userName', verifiedName);
        document.getElementById('verifiedMsg').textContent = 'Thanks, ' + verifiedName + '. Redirecting to home...';
      }
      showView('thank-you');
      openAuth();
      setTimeout(() => { backToHome(); }, 4000);
    } else {
      const storedName = localStorage.getItem('userName');
      if (storedName) updateNavbar(storedName);
    }

    // SIGNUP
    const signupForm = document.getElementById('signupForm');
    if (signupForm) {
      signupForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const name = document.getElementById('name').value.trim();
        const email = document.getElementById('email').value.trim();
        const password = document.getElementById('password').value;
        const msg = document.getElementById('formMessage');
        msg.style.color = '#ffb3b3';
        msg.textContent = 'Processing...';
        try {
          const res = await fetch('/auth/signup', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ name, email, password })
          });
          const data = await res.json();
          if (res.ok) {
            msg.style.color = '#b3ffdf';
            msg.textContent = data.message || 'Registered. Check your email to verify.';
            if (data.name) { localStorage.setItem('userName', data.name); updateNavbar(data.name); }
          } else {
            msg.style.color = '#ffb3b3';
            msg.textContent = (data && data.message) ? data.message : 'Signup failed.';
          }
        } catch (err) {
          msg.style.color = '#ffb3b3';
          msg.textContent = 'Network error. Try again.';
        }
      });
    }

    // LOGIN
    const loginForm = document.getElementById('loginForm');
    if (loginForm) {
      loginForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('loginEmail').value.trim();
        const password = document.getElementById('loginPassword').value;
        const msg = document.getElementById('loginMessage');
        msg.style.color = '#ffb3b3';
        msg.textContent = 'Checking...';
        try {
          const res = await fetch('/auth/login', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email, password })
          });
          const data = await res.json();
          if (res.ok) {
            msg.style.color = '#b3ffdf';
            msg.textContent = data.message || 'Logged in';
            if (data.name) { localStorage.setItem('userName', data.name); updateNavbar(data.name); }
            setTimeout(() => closeAuth(), 700);
          } else {
            if (data && data.needVerify) {
              msg.style.color = '#ffd89b';
              msg.innerHTML = 'Account not verified. <a href="#" onclick="resendVerify(\'' + (data.email || email) + '\')">Resend link</a>';
            } else {
              msg.style.color = '#ffb3b3';
              msg.textContent = (data && data.message) ? data.message : 'Login failed';
            }
          }
        } catch (err) {
          msg.style.color = '#ffb3b3';
          msg.textContent = 'Network error. Try again.';
        }
      });
    }

    // FORGOT (robust)
    const forgotForm = document.getElementById('forgotForm');
    if (forgotForm) {
      forgotForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('forgotEmail').value.trim();
        const msg = document.getElementById('forgotMessage');
        msg.style.color = '#ffb3b3';
        msg.textContent = 'Processing...';
        try {
          const res = await fetch('/auth/forgot', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email })
          });

          // parse response safely
          const cType = res.headers.get('content-type') || '';
          let data;
          if (cType.includes('application/json')) {
            data = await res.json();
          } else {
            const text = await res.text();
            try { data = JSON.parse(text); } catch (err) { data = { message: text || (res.ok ? 'Request completed' : 'Server error') }; }
          }

          msg.style.color = res.ok ? '#b3ffdf' : '#ffb3b3';
          msg.textContent = data && data.message ? data.message : 'If that account exists a reset email has been sent.';
        } catch (err) {
          console.error('Fetch/Network error on forgot:', err);
          msg.style.color = '#ffb3b3';
          msg.textContent = 'Network error. Try again later.';
        }
      });
    }
  });

  // resend verification helper
  async function resendVerify(email) {
    try {
      const res = await fetch('/auth/resend', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });
      const data = await res.json();
      alert(data.message || 'If that account exists, verification was resent.');
    } catch (err) {
      alert('Could not resend. Try again.');
    }
  }

  const openBtn = document.getElementById('openAuthBtn');
  if (openBtn) openBtn.addEventListener('click', () => { switchTab('login'); });

  // simple hamburger toggle (if your CSS uses it)
  const hamburger = document.querySelector('.hamburger');
  const navLinks = document.querySelector('.nav-links');
  if (hamburger && navLinks) {
    const navIcon = hamburger.querySelector('i');
    hamburger.addEventListener('click', () => {
      navLinks.classList.toggle('active');
      if (navLinks.classList.contains('active')) {
        navIcon.classList.remove('fa-bars'); navIcon.classList.add('fa-times');
      } else { navIcon.classList.remove('fa-times'); navIcon.classList.add('fa-bars'); }
    });
  }
</script>
