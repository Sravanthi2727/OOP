<% layout('layouts/boilerplate') %>
<div style="padding:4rem;max-width:600px;margin:0 auto;">
  <% if (!valid) { %>
    <h2>Error</h2>
    <p><%= message || 'Invalid link' %></p>
    <a href="/">Back to home</a>
  <% } else { %>
    <h2>Reset Password</h2>
    <form method="POST" action="/auth/reset">
      <input type="hidden" name="email" value="<%= email %>"/>
      <input type="hidden" name="token" value="<%= token %>"/>
      <div style="margin:1rem 0;">
        <label>New password (min 8)</label><br/>
        <input type="password" name="password" required minlength="8" style="width:100%;padding:8px;"/>
      </div>
      <button type="submit" style="padding:8px 16px;">Save</button>
    </form>
  <% } %>
</div>
