<% layout('layouts/boilerplate') %>

<%
// Helper: Recursively render a value that could be:
// - an array of items (books/resources) where each item is either a string or an object with properties (title, author, link, read_online, etc.)
// - an object whose keys are category names => values (array | object)
// We'll output nested headings and lists to mirror JSON structure.
function renderResourceValue(val, headingLevel) {
  // headingLevel: integer (2 => <h2>, 3 => <h3>, etc.)
  const h = n => {
    const lvl = Math.min(Math.max(n,2),6);
    return 'h' + lvl;
  };

  if (!val) {
    %>
    <p class="text-muted">No items.</p>
    <%
    return;
  }

  // If array: output list of items
  if (Array.isArray(val)) {
    %>
    <ul class="list-unstyled mb-3">
      <% val.forEach(function(item){ %>
        <li class="mb-2">
          <% if (typeof item === 'string') { %>
            <%= item %>
          <% } else { %>
            <strong><%= item.title || item.name || item.label || 'Untitled' %></strong>
            <% if (item.author) { %> — <em><%= item.author %></em><% } %>
            <% if (item.platform) { %> — <small><%= item.platform %></small><% } %>
            <% if (item.link || item.read_online) { %>
              <div><a href="<%= item.link || item.read_online %>" target="_blank" rel="noopener noreferrer">Open</a></div>
            <% } %>
            <% if (item.focus) { %><div class="small text-muted"><%= item.focus %></div><% } %>
          <% } %>
        </li>
      <% }) %>
    </ul>
    <%
    return;
  }

  // If object: iterate keys and render each part
  if (typeof val === 'object') {
    Object.keys(val).forEach(function(key){
      const child = val[key];
      %>
      <<%= h(headingLevel) %> class="mt-3 mb-1"><%= key %></<%= h(headingLevel) %>>
      <%
      // If the child is a simple array or object that looks like a named-list (array of items), render it directly with a slightly smaller headingLevel +1
      if (Array.isArray(child)) {
        renderResourceValue(child, headingLevel + 1);
      } else if (typeof child === 'object') {
        // If it's an object with further nested categories (e.g. "Android": { "books": [...], "notes": [...] })
        // Try to detect if this object itself is a simple book-like object (contains title/author) or a category group.
        const maybeBookLike = child.title || child.author || child.read_online || child.link;
        if (maybeBookLike) {
          // treat as single book object
          renderResourceValue([child], headingLevel + 1);
        } else {
          // deeper categories: recurse
          renderResourceValue(child, headingLevel + 1);
        }
      } else {
        // fallback: print value
        %><p class="text-muted"><%= String(child) %></p><%
      }
    });
    return;
  }

  // fallback string
  %><p class="text-muted"><%= String(val) %></p><%
}
%>

<main class="my-5">
  <div class="mb-3">
  <a href="/courses" class="btn btn-outline-primary">
    <i class="fa-solid fa-arrow-left"></i> Back to Courses
  </a>
</div>
  <div class="card border-0 shadow-sm">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-start">
        <div style="max-width:75%">
          <h1 class="h3 text-info"><%= course.title %></h1>

          <% if (course.intro && course.intro.description) { %>
            <p class="text-muted"><%= course.intro.description %></p>
          <% } else if (course.roadmap && course.roadmap.summary) { %>
            <p class="text-muted"><%= course.roadmap.summary %></p>
          <% } else { %>
            <p class="text-muted">No summary available.</p>
          <% } %>

          <% if (course.tags && course.tags.length) { %>
          <div class="mb-3">
            <% course.tags.forEach(tag => { %>
              <span class="badge bg-info text-dark me-1"><%= tag %></span>
            <% }) %>
          </div>
          <% } %>
        </div>

        <div class="text-end">
          <% /* Optional Start link: keep or remove as you prefer */ %>
          <% if (course.courses && course.courses.free && course.courses.free[0] && course.courses.free[0].link) { %>
            <a class="btn btn-primary btn-lg mb-2" href="<%= course.courses.free[0].link %>" target="_blank">Start Free</a>
          <% } %>

          <% if (course.roadmap && (course.roadmap.source || course.roadmap.link)) { %>
            <div>
              <a href="<%= course.roadmap.source || course.roadmap.link %>" target="_blank" rel="noopener noreferrer" class="btn btn-outline-info btn-sm">View Roadmap</a>
            </div>
          <% } %>
        </div>
      </div>

      <hr />

      <h5>Roadmap / Summary</h5>
      <p class="text-muted">
        <%= (course.roadmap && course.roadmap.summary) || 'No roadmap available' %>
      </p>

      <% if (course.roadmap && (course.roadmap.source || course.roadmap.link)) { %>
      <p class="mb-3">
        <a href="<%= course.roadmap.source || course.roadmap.link %>" target="_blank" rel="noopener noreferrer">
          <small class="text-info">Open roadmap source</small>
        </a>
      </p>
      <% } %>

      <hr />

      <h5>Books & Resources</h5>
      <div class="mb-3">
        <% if (!course.books) { %>
          <p class="text-muted">No books/resources listed.</p>
        <% } else { %>
          <% // Render books section robustly %>
          <% renderResourceValue(course.books, 3); %>
        <% } %>
      </div>

      <% if (course.courses) { %>
      <h5>Courses</h5>
      <div class="row">
        <% Object.keys(course.courses).forEach(k => { %>
          <div class="col-md-4 mb-3">
            <h6 class="mb-2 text-capitalize"><%= k.replace(/_/g,' ') %></h6>
            <% const arr = course.courses[k] || []; %>
            <% if (Array.isArray(arr) && arr.length) { %>
              <ul class="list-unstyled">
                <% arr.forEach(item => { %>
                  <li class="mb-2">
                    <strong><%= item.title || item.platform || item.name || 'Untitled' %></strong>
                    <% if (item.platform) { %> — <em><%= item.platform %></em><% } %>
                    <% if (item.link) { %>
                      <div><a href="<%= item.link %>" target="_blank">Open</a></div>
                    <% } %>
                  </li>
                <% }) %>
              </ul>
            <% } else if (typeof arr === 'object' && Object.keys(arr).length) { %>
              <% // nested object categories inside courses[k] %>
              <% Object.keys(arr).forEach(sub => { %>
                <h6 class="mt-2 mb-1"><%= sub %></h6>
                <% renderResourceValue(arr[sub], 5); %>
              <% }) %>
            <% } else { %>
              <p class="text-muted">No courses listed under <%= k %>.</p>
            <% } %>
          </div>
        <% }) %>
      </div>
      <% } %>

    </div>
  </div>
</main>
